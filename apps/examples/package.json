{
  "name": "examples",
  "version": "0.6.0",
  "private": true,
  "homepage": "http://typeahead.tomocchino.com",
  "scripts": {
    "dev": "next dev --turbopack",
    "lint": "eslint .",
    "build": "next build",
    "start": "next start",
    "predist": "mkdir -p build package && cp -R {release/*,src} package",
    "dist": "cd package && tsc && cp -R src/css dist && npm pack --pack-destination ../build",
    "postdist": "rm -rf package",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tomocchino/typeahead": "workspace:*",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "emojibase": "^17.0.0",
    "lucide-react": "^0.562.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/node": "^25.9.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "turbo": "^2.10.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.0.0"
}
